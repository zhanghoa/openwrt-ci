CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
# CONFIG_TARGET_MULTI_PROFILE is not set
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_zn_m2=y

# System Performance Tuning
CONFIG_COREMARK_ENABLE_MULTITHREADING=y
CONFIG_COREMARK_NUMBER_OF_THREADS=16
CONFIG_COREMARK_OPTIMIZE_O3=y
CONFIG_LUCI_LANG_zh_Hans=y

# Core Libraries
CONFIG_PACKAGE_libmbedtls=y

# IPTV Multicast to Unicast Components
CONFIG_PACKAGE_igmpproxy=y
CONFIG_PACKAGE_udpxy=y
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-i18n-udpxy-zh-cn=y

# LuCI Applications & Themes
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon=y

# Force Disable Wireless Drivers & Protocols
# CONFIG_DRIVER_11AC_SUPPORT is not set
# CONFIG_DRIVER_11AX_SUPPORT is not set
# CONFIG_PACKAGE_kmod-ath11k is not set
# CONFIG_PACKAGE_kmod-ath11k-ahb is not set
# CONFIG_PACKAGE_kmod-ath11k-pci is not set
# CONFIG_PACKAGE_kmod-mac80211 is not set
# CONFIG_PACKAGE_hostapd-common is not set
# CONFIG_PACKAGE_wpad-openssl is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set
# CONFIG_PACKAGE_iwinfo is not set
# CONFIG_PACKAGE_kmod-ath is not set
# CONFIG_PACKAGE_kmod-cfg80211 is not set
# CONFIG_ATH11K_NSS_SUPPORT is not set

# Force Disable NSS Acceleration Routing Engines (Keep DP/DRV)
# CONFIG_PACKAGE_kmod-qca-nss-ecm is not set
# CONFIG_PACKAGE_kmod-qca-nss-crypto is not set
# CONFIG_PACKAGE_luci-app-turboacc is not set

# Force Disable Proxy Applications
# CONFIG_PACKAGE_chinadns-ng is not set
# CONFIG_PACKAGE_sing-box is not set
# CONFIG_PACKAGE_smartdns is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set
# CONFIG_PACKAGE_luci-app-smartdns is not set

CONFIG_PACKAGE_kmod-qca-nss-ecm=n
CONFIG_PACKAGE_kmod-qca-nss-crypto=n
